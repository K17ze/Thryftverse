{
  "name": "thryftverse-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/db/migrate.ts",
    "start": "node --enable-source-maps dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.882.0",
    "@aws-sdk/s3-request-presigner": "^3.882.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1",
    "ioredis": "^5.7.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
