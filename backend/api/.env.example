# Thryftverse Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Core ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://thryftverse:thryftverse@localhost:5432/thryftverse
REDIS_URL=redis://localhost:6379

# ── Key Service ──────────────────────────────────────────
KEY_SERVICE_URL=http://localhost:4100
KEY_SERVICE_CLIENT_TOKEN=local-key-client-token
KEY_SERVICE_ADMIN_TOKEN=local-key-admin-token

# ── S3 / MinIO ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=thryftverse-media
S3_FORCE_PATH_STYLE=true

# ── ML Service ───────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────
AUTH_ACCESS_TOKEN_SECRET=your-access-token-secret
AUTH_REFRESH_TOKEN_SECRET=your-refresh-token-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_HASH_COST=12
AUTH_EMAIL_PROVIDER=log
# AUTH_EMAIL_FROM=noreply@thryftverse.app
# RESEND_API_KEY=your-resend-api-key

# ── Google / Apple OAuth ─────────────────────────────────
# GOOGLE_OAUTH_CLIENT_IDS=your-android-client-id,your-ios-client-id,your-web-client-id
# APPLE_OAUTH_AUDIENCE=com.thryftverse.app

# ── Payment Providers ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# WISE_API_KEY=your-wise-api-key
# WISE_WEBHOOK_SECRET=your-wise-webhook-secret

# ── KYC ──────────────────────────────────────────────────
KYC_DEFAULT_VENDOR=sandbox_kyc_vendor
KYC_VERIFICATION_BASE_URL=https://verify.thryftverse.local/session

# ── Security ─────────────────────────────────────────────
API_SECURITY_ADMIN_TOKEN=local-security-admin-token
API_RATE_LIMIT_MAX=140
API_RATE_LIMIT_WINDOW=1 minute

# ── Observability ────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.15
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_HTTP_URL=http://localhost:4318/v1/traces

# ── Gold / 1ze ───────────────────────────────────────────
# GOLD_ORACLE_API_URL=https://api.metals.dev/v1/latest
# GOLD_ORACLE_API_KEY=xxx
ONEZE_ATTESTATION_SIGNING_SECRET=dev-only-oneze-attestation-signing-secret
